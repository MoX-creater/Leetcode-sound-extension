{
  "manifest_version": 3,
  "name": "LeetCode Sound Notifications",
  "version": "1.2",
  "description": "Plays a sound on successful or failed LeetCode submissions.",
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "http://leetcode.com/*",
        "https://www.leetcode.com/*",
        "http://www.leetcode.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://leetcode.com/*",
        "http://leetcode.com/*",
        "https://www.leetcode.com/*",
        "http://www.leetcode.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "success.mp3",
        "error.mp3"
      ],
      "matches": [
        "https://leetcode.com/*",
        "http://leetcode.com/*",
        "https://www.leetcode.com/*",
        "http://www.leetcode.com/*"
      ]
    }
  ]
}